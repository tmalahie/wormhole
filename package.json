{
  "name": "wormhole",
  "version": "0.1.0",
  "description": "Manage warm, parallel git worktree environments for AI coding agents.",
  "type": "module",
  "bin": {
    "worm": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm build",
    "test": "node --test tests/*.test.mjs",
    "predemo": "pnpm build",
    "demo": "bash scripts/demo.sh",
    "worm": "node ./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
